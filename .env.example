# Datos personales (OBLIGATORIO — rellenar antes de ejecutar)
NIE=X1234567A
NOMBRE=NOMBRE APELLIDO1 APELLIDO2

# Depuración (OPCIONAL — ejecutar solo hasta un paso concreto, 0-5)
# Siempre empieza desde el paso 0. Si es menor que 5, ejecuta una sola vez y para.
# 0=Solo navegación, 1=Provincia, 2=Trámite, 3=Aviso, 4=Datos personales, 5=Ciclo completo
PASO_HASTA=5

# --- Cadencia (OPCIONAL — valores por defecto si no se especifican) ---

INTERVALO_REINTENTO_SEGUNDOS=120
TIMEOUT_CARGA_PAGINA_SEGUNDOS=15
TIMEOUT_ESPERA_ELEMENTO_SEGUNDOS=10

# --- Delays humanizados v2 (OPCIONAL — valores por defecto sensatos) ---
# Todos los tiempos son rangos [min, max] en segundos.
# La personalidad del ciclo (rapido/normal/lento) multiplica estos rangos.

# Polling de waitForElement (milisegundos)
WAIT_ELEMENT_POLL_MS=300

# --- Aterrizaje (orientación visual al cargar página) ---
ATERRIZAJE_PAUSA_MIN=1.0
ATERRIZAJE_PAUSA_MAX=3.0
ATERRIZAJE_MICRO_MOV_MIN=1
ATERRIZAJE_MICRO_MOV_MAX=2
ATERRIZAJE_MOV_RANGO_X=80
ATERRIZAJE_MOV_RANGO_Y=50
ATERRIZAJE_MOV_DURACION_MIN=0.2
ATERRIZAJE_MOV_DURACION_MAX=0.5
ATERRIZAJE_SCROLL_PROB=0.30
ATERRIZAJE_SCROLL_DIST_MIN=50
ATERRIZAJE_SCROLL_DIST_MAX=150

# --- Interacción con elementos ---
PRE_INTERACCION_PAUSA_MIN=0.4
PRE_INTERACCION_PAUSA_MAX=1.2
MOUSE_TRAYECTORIA_DURACION_MIN=0.3
MOUSE_TRAYECTORIA_DURACION_MAX=0.8
MOUSE_OVERSHOOT_PROB=0.12
MOUSE_OVERSHOOT_DIST_MIN=15
MOUSE_OVERSHOOT_DIST_MAX=40
MOUSE_OVERSHOOT_PAUSA_MIN=0.1
MOUSE_OVERSHOOT_PAUSA_MAX=0.3
CLICK_PRESS_RELEASE_MIN=50
CLICK_PRESS_RELEASE_MAX=150

# --- Recorrido de desplegable ---
DESPLEGABLE_PAUSA_APERTURA_MIN=0.3
DESPLEGABLE_PAUSA_APERTURA_MAX=0.8
DESPLEGABLE_SCROLL_ITER_MIN=1
DESPLEGABLE_SCROLL_ITER_MAX=2
DESPLEGABLE_ARROW_POR_ITER_MIN=2
DESPLEGABLE_ARROW_POR_ITER_MAX=4
DESPLEGABLE_ARROW_DELAY_MIN=0.15
DESPLEGABLE_ARROW_DELAY_MAX=0.4
DESPLEGABLE_ITER_PAUSA_MIN=0.4
DESPLEGABLE_ITER_PAUSA_MAX=1.0
DESPLEGABLE_NAV_DELAY_MIN=0.1
DESPLEGABLE_NAV_DELAY_MAX=0.3
DESPLEGABLE_DECISION_MIN=0.2
DESPLEGABLE_DECISION_MAX=0.6

# --- Fase 1: Scroll inicial obligatorio ---
F1_SCROLL_INICIAL_DIST_MIN=80
F1_SCROLL_INICIAL_DIST_MAX=200

# --- Fase 2: Scroll exhaustivo + botón Entrar ---
F2_SCROLL_DIST_MIN=100
F2_SCROLL_DIST_MAX=250
F2_SCROLL_PAUSA_MIN=0.5
F2_SCROLL_PAUSA_MAX=1.5

# --- Transición entre acciones ---
TRANSICION_PAUSA_MIN=0.5
TRANSICION_PAUSA_MAX=1.5
TRANSICION_IDLE_PROB=0.40
TRANSICION_IDLE_RANGO=20
TRANSICION_EXTRA_PROB=0.20
TRANSICION_EXTRA_MIN=0.5
TRANSICION_EXTRA_MAX=2.0

# --- Focus → Click (intervalo entre focus y click en botones de envío) ---
FOCUS_CLICK_MIN=0.35
FOCUS_CLICK_MAX=0.65

# --- Personalidad (multiplicadores de tiempos) ---
PERSONALIDAD_FACTOR_RAPIDO=0.6
PERSONALIDAD_FACTOR_NORMAL=1.0
PERSONALIDAD_FACTOR_LENTO=1.5

# --- Delays v1 (usados por fases no migradas aún) ---
DELAY_ACCION_BASE=2.0
DELAY_ACCION_VARIANZA=0.8
DELAY_SCROLL_MIN=0.8
DELAY_SCROLL_MAX=2.0
DELAY_EVALUACION_MIN=2.0
DELAY_EVALUACION_MAX=5.0
PAUSA_ENTRE_PASOS_MIN=2.0
PAUSA_ENTRE_PASOS_MAX=5.0

# --- WAF (Web Application Firewall) ---
# Si el portal te banea frecuentemente, aumenta estos valores

# Espera tras el primer ban del WAF (segundos). Backoff exponencial: base × 2^(n-1)
WAF_BACKOFF_BASE_SEGUNDOS=300

# Espera máxima tras bans consecutivos (segundos)
WAF_BACKOFF_MAX_SEGUNDOS=900

# Número de bans consecutivos antes de mostrar alerta en el log
WAF_BACKOFF_UMBRAL_ALERTA=3
