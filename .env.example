# Datos personales (OBLIGATORIO — rellenar antes de ejecutar)
NIE=X1234567A
NOMBRE=NOMBRE APELLIDO1 APELLIDO2

# Depuración (OPCIONAL — ejecutar solo hasta un paso concreto, 0-5)
# Siempre empieza desde el paso 0. Si es menor que 5, ejecuta una sola vez y para.
# 0=Solo navegación, 1=Provincia, 2=Trámite, 3=Aviso, 4=Datos personales, 5=Ciclo completo
PASO_HASTA=5

# --- Cadencia (OPCIONAL — valores por defecto si no se especifican) ---

INTERVALO_REINTENTO_SEGUNDOS=120
TIMEOUT_CARGA_PAGINA_SEGUNDOS=15
TIMEOUT_ESPERA_ELEMENTO_SEGUNDOS=10

# --- Delays humanizados (OPCIONAL) ---

# Acciones de formulario: delay = base + random(0, base * varianza). Ej: 2.0 + 80% → [2.0, 3.6]s
DELAY_ACCION_BASE=2.0
DELAY_ACCION_VARIANZA=0.8

# Scroll humano entre pasos de scroll: rango uniforme [min, max] segundos
DELAY_SCROLL_MIN=0.8
DELAY_SCROLL_MAX=2.0

# Lectura de página antes de evaluar resultado: rango uniforme [min, max] segundos
DELAY_EVALUACION_MIN=2.0
DELAY_EVALUACION_MAX=5.0

# Pausa entre formularios (simula lectura/pensamiento): rango uniforme [min, max] segundos
PAUSA_ENTRE_PASOS_MIN=2.0
PAUSA_ENTRE_PASOS_MAX=5.0

# --- WAF (Web Application Firewall) ---
# Si el portal te banea frecuentemente, aumenta estos valores

# Espera tras el primer ban del WAF (segundos). Backoff exponencial: base × 2^(n-1)
WAF_BACKOFF_BASE_SEGUNDOS=300

# Espera máxima tras bans consecutivos (segundos)
WAF_BACKOFF_MAX_SEGUNDOS=900

# Número de bans consecutivos antes de mostrar alerta en el log
WAF_BACKOFF_UMBRAL_ALERTA=3
